# ClinikChat Production Environment
# Generated by setup.sh — edit as needed

# Domain (used for CORS and URLs)
DOMAIN=localhost

# PostgreSQL
POSTGRES_USER=clinikchat
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=clinikchat

# MinIO / S3
MINIO_ROOT_USER=clinikchat-minio
MINIO_ROOT_PASSWORD=CHANGE_ME

# JWT (must be long random strings)
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# CORS origin (set to your domain)
CORS_ORIGIN=http://localhost

# Ports (change if behind another reverse proxy)
HTTP_PORT=80
HTTPS_PORT=443
