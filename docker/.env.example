# PostgreSQL
POSTGRES_USER=clinikchat
POSTGRES_PASSWORD=clinikchat
POSTGRES_DB=clinikchat
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO (S3-compatible)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123456
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API (used by packages/api — copy to packages/api/.env)
DATABASE_URL=postgresql://clinikchat:clinikchat@localhost:5432/clinikchat
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173
PORT=3001
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123456
S3_BUCKET=clinikchat-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
