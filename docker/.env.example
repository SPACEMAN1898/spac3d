# ============================================================
# ClinikChat Development Environment Variables
# Copy this file to docker/.env and fill in your values
# ============================================================

# PostgreSQL
POSTGRES_DB=clinikchat_dev
POSTGRES_USER=clinikchat
POSTGRES_PASSWORD=clinikchat_password
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# MinIO Object Storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# API Server
NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://clinikchat:clinikchat_password@localhost:5432/clinikchat_dev
REDIS_URL=redis://localhost:6379

# JWT Secrets (change these in production!)
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# MinIO (S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=clinikchat-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_password
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Cookie
COOKIE_SECRET=your-cookie-secret-change-in-production
