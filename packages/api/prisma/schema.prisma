generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ONLINE
  AWAY
  OFFLINE
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  PUBLIC
  PRIVATE
  DM
}

enum MessageType {
  TEXT
  SYSTEM
  FILE
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  email               String               @unique
  displayName         String
  avatarUrl           String?
  passwordHash        String
  status              UserStatus           @default(OFFLINE)
  lastSeenAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ownedOrganizations  Organization[]       @relation("OrganizationOwner")
  memberships         OrganizationMember[]
  createdChannels     Channel[]            @relation("ChannelCreator")
  channelMemberships  ChannelMember[]
  messages            Message[]
  refreshTokens       RefreshToken[]
}

model Organization {
  id         String               @id @default(uuid()) @db.Uuid
  name       String
  slug       String               @unique
  settings   Json                 @default("{}")
  ownerId    String               @db.Uuid
  owner      User                 @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members    OrganizationMember[]
  channels   Channel[]
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
}

model OrganizationMember {
  id        String       @id @default(uuid()) @db.Uuid
  orgId     String       @db.Uuid
  userId    String       @db.Uuid
  role      MemberRole   @default(MEMBER)
  joinedAt  DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

model Channel {
  id           String          @id @default(uuid()) @db.Uuid
  orgId        String          @db.Uuid
  name         String
  topic        String?
  type         ChannelType     @default(PUBLIC)
  createdById  String          @db.Uuid
  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy    User            @relation("ChannelCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members      ChannelMember[]
  messages     Message[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model ChannelMember {
  id         String      @id @default(uuid()) @db.Uuid
  channelId  String      @db.Uuid
  userId     String      @db.Uuid
  role       MemberRole  @default(MEMBER)
  lastReadAt DateTime?
  joinedAt   DateTime    @default(now())
  channel    Channel     @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
}

model Message {
  id          String       @id @default(uuid()) @db.Uuid
  channelId   String       @db.Uuid
  userId      String       @db.Uuid
  content     String       @db.Text
  type        MessageType  @default(TEXT)
  parentId    String?      @db.Uuid
  editedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent      Message?     @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies     Message[]    @relation("MessageThread")
  attachments Attachment[]

  @@index([channelId, createdAt(sort: Desc)])
}

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  messageId  String   @db.Uuid
  filename   String
  mimeType   String
  size       Int
  storageKey String
  createdAt  DateTime @default(now())
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
