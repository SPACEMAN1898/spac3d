generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ONLINE
  AWAY
  OFFLINE
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum ChannelType {
  PUBLIC
  PRIVATE
  DM
}

enum ChannelMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum MessageType {
  TEXT
  SYSTEM
  FILE
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique
  displayName  String
  avatarUrl    String?
  passwordHash String
  status       UserStatus @default(OFFLINE)
  lastSeenAt   DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  organizations   OrganizationMember[]
  ownedOrgs       Organization[]       @relation("OrgOwner")
  channels        ChannelMember[]
  messages        Message[]
  createdChannels Channel[]            @relation("ChannelCreator")
  refreshTokens   RefreshToken[]

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  settings  Json     @default("{}")
  ownerId   String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner    User                 @relation("OrgOwner", fields: [ownerId], references: [id])
  members  OrganizationMember[]
  channels Channel[]

  @@map("organizations")
}

model OrganizationMember {
  orgId    String        @db.Uuid
  userId   String        @db.Uuid
  role     OrgMemberRole @default(MEMBER)
  joinedAt DateTime      @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([orgId, userId])
  @@map("organization_members")
}

model Channel {
  id          String      @id @default(uuid()) @db.Uuid
  orgId       String      @db.Uuid
  name        String
  topic       String?
  type        ChannelType @default(PUBLIC)
  createdById String      @db.Uuid
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  org       Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User            @relation("ChannelCreator", fields: [createdById], references: [id])
  members   ChannelMember[]
  messages  Message[]

  @@map("channels")
}

model ChannelMember {
  channelId  String            @db.Uuid
  userId     String            @db.Uuid
  role       ChannelMemberRole @default(MEMBER)
  lastReadAt DateTime?
  joinedAt   DateTime          @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@map("channel_members")
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  channelId String      @db.Uuid
  userId    String      @db.Uuid
  content   String
  type      MessageType @default(TEXT)
  parentId  String?     @db.Uuid
  editedAt  DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  channel     Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id])
  parent      Message?     @relation("MessageThread", fields: [parentId], references: [id])
  replies     Message[]    @relation("MessageThread")
  attachments Attachment[]
  reactions   Reaction[]

  @@index([channelId, createdAt(sort: Desc)])
  @@map("messages")
}

model Attachment {
  id         String   @id @default(uuid()) @db.Uuid
  messageId  String   @db.Uuid
  filename   String
  mimeType   String
  size       Int
  storageKey String
  createdAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Reaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("reactions")
}

model PushToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  platform  String   @default("expo")
  createdAt DateTime @default(now())

  @@map("push_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
