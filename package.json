{
  "name": "clinikchat",
  "private": true,
  "packageManager": "pnpm@10.5.2",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "docker:dev": "docker compose --env-file docker/.env.example -f docker/docker-compose.dev.yml up -d",
    "docker:down": "docker compose --env-file docker/.env.example -f docker/docker-compose.dev.yml down"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
